[options]
mode cover
depth 8
wait on

[engines]
smtbmc z3

[script]
read_verilog -formal -sv formal_defs.svh
read_verilog -formal -sv debug_sc_system_v3_map.svh
read_verilog -formal -sv props_sc_decode.sv
read_verilog -formal -sv sc_decode_formal_tb.sv
prep -top sc_decode_formal_tb

[files]
../common/formal_defs.svh
debug_sc_system_v3_map.svh
props_sc_decode.sv
sc_decode_formal_tb.sv
