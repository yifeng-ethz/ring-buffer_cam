	component scifi_datapath_system_v3 is
		port (
			avmm_clk_clk                   : in  std_logic                     := 'X';             -- clk
			avmm_port_waitrequest          : out std_logic;                                        -- waitrequest
			avmm_port_readdata             : out std_logic_vector(31 downto 0);                    -- readdata
			avmm_port_readdatavalid        : out std_logic;                                        -- readdatavalid
			avmm_port_burstcount           : in  std_logic_vector(8 downto 0)  := (others => 'X'); -- burstcount
			avmm_port_writedata            : in  std_logic_vector(31 downto 0) := (others => 'X'); -- writedata
			avmm_port_address              : in  std_logic_vector(13 downto 0) := (others => 'X'); -- address
			avmm_port_write                : in  std_logic                     := 'X';             -- write
			avmm_port_read                 : in  std_logic                     := 'X';             -- read
			avmm_port_byteenable           : in  std_logic_vector(3 downto 0)  := (others => 'X'); -- byteenable
			avmm_port_debugaccess          : in  std_logic                     := 'X';             -- debugaccess
			avmm_rst_reset                 : in  std_logic                     := 'X';             -- reset
			counter_sclr_reset             : in  std_logic                     := 'X';             -- reset
			hit_type3_lower_data           : out std_logic_vector(35 downto 0);                    -- data
			hit_type3_lower_valid          : out std_logic;                                        -- valid
			hit_type3_lower_ready          : in  std_logic                     := 'X';             -- ready
			hit_type3_lower_startofpacket  : out std_logic;                                        -- startofpacket
			hit_type3_lower_endofpacket    : out std_logic;                                        -- endofpacket
			hit_type3_upper_ready          : in  std_logic                     := 'X';             -- ready
			hit_type3_upper_valid          : out std_logic;                                        -- valid
			hit_type3_upper_startofpacket  : out std_logic;                                        -- startofpacket
			hit_type3_upper_endofpacket    : out std_logic;                                        -- endofpacket
			hit_type3_upper_empty          : out std_logic_vector(0 downto 0);                     -- empty
			hit_type3_upper_data           : out std_logic_vector(35 downto 0);                    -- data
			inject_pulse                   : out std_logic;                                        -- pulse
			inject_masked_pulse            : out std_logic;                                        -- masked_pulse
			inject_aux_pulse               : in  std_logic                     := 'X';             -- pulse
			lvds_outclock_clk              : out std_logic;                                        -- clk
			lvds_pll_inclock_clk           : in  std_logic                     := 'X';             -- clk
			monitor_clock_125_in_clk       : in  std_logic                     := 'X';             -- clk
			monitor_reset_in_reset_reset_n : in  std_logic                     := 'X';             -- reset_n
			mutrig_reset_reset             : out std_logic_vector(1 downto 0);                     -- reset
			osc_clock_50_in_clk            : in  std_logic                     := 'X';             -- clk
			redriver_losn                  : in  std_logic_vector(8 downto 0)  := (others => 'X'); -- losn
			rstlink_data                   : out std_logic_vector(8 downto 0);                     -- data
			rstlink_channel                : out std_logic_vector(3 downto 0);                     -- channel
			rstlink_error                  : out std_logic_vector(2 downto 0);                     -- error
			runctl_mgmt_host_ready         : out std_logic;                                        -- ready
			runctl_mgmt_host_valid         : in  std_logic                     := 'X';             -- valid
			runctl_mgmt_host_data          : in  std_logic_vector(8 downto 0)  := (others => 'X'); -- data
			serial_data                    : in  std_logic_vector(8 downto 0)  := (others => 'X'); -- data
			xcvr_clock_clk                 : in  std_logic                     := 'X';             -- clk
			xcvr_reset_reset_n             : in  std_logic                     := 'X'              -- reset_n
		);
	end component scifi_datapath_system_v3;

