foreach f [ lsort [ glob -directory $::quartus(qip_path) \
    "*.vhd" \
] ] {
    set_global_assignment -name VHDL_FILE $f
}

set_global_assignment -name QIP_FILE [file join $::quartus(qip_path) "reset_shift/include.qip"]
