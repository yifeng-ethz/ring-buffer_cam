set_global_assignment -name QIP_FILE [file join $::quartus(qip_path) "frame_rcv/include.qip"]
set_global_assignment -name QIP_FILE [file join $::quartus(qip_path) "framebuilder_mux/include.qip"]
set_global_assignment -name QIP_FILE [file join $::quartus(qip_path) "channelmux/vhd/include.qip"]
set_global_assignment -name QIP_FILE [file join $::quartus(qip_path) "prbs_dec/source/include.qip"]
set_global_assignment -name QIP_FILE [file join $::quartus(qip_path) "lapse/include.qip"]
