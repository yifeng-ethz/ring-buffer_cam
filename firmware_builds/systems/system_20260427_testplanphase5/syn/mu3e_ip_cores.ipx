 <component name="onewire_master" file="../../../../onewire_temp_sense/onewire_master_hw.tcl" displayName="OneWire Master" version="24.1.423" description="&lt;html&gt; Handles link layer transaction in &lt;b&gt;1-Wire&lt;/b&gt; protocol. &lt;br&gt; &lt;br&gt; Usage: &lt;ul&gt;   &lt;li&gt;&lt;b&gt;TX Flow&lt;/b&gt;:&lt;/li&gt;   &lt;ol&gt;   &lt;li&gt;send data through &lt;b&gt;tx&lt;/b&gt; port. &lt;br&gt; &lt;/li&gt;   &lt;li&gt;issue command through &lt;b&gt;ctrl&lt;/b&gt; port. &lt;br&gt; &lt;/li&gt;  &lt;/ol&gt;  &lt;li&gt;&lt;b&gt;RX Flow&lt;/b&gt;:&lt;/li&gt;   &lt;ol&gt;   &lt;li&gt;issue command through &lt;b&gt;ctrl&lt;/b&gt; port. &lt;br&gt; &lt;/li&gt;   &lt;li&gt;retrieve data from &lt;b&gt;rx&lt;/b&gt; port. &lt;br&gt; &lt;/li&gt;  &lt;/ol&gt; &lt;/ul&gt; &lt;/html&gt;" tags="AUTHORSHIP=Yifeng Wang /// CONNECTION_TYPES=avalon,avalon_streaming,clock,conduit,interrupt,reset /// INTERNAL_COMPONENT=false" categories="Mu3e Control Plane/Modules" factory="TclModuleFactory">
  <tag2 key="ALLOW_GREYBOX_GENERATION" value="false" />
  <tag2 key="COMPONENT_EDITABLE" value="false" />
  <tag2 key="COMPONENT_HIDE_FROM_SOPC" value="true" />
  <tag2 key="ELABORATION_CALLBACK" value="my_elaborate" />
  <tag2 key="ICON_PATH" value="../../../misc/logo/mu3e_logo.png" />
  <tag2 key="INSTANTIATE_IN_SYSTEM_MODULE" value="true" />
  <tag2 key="OPAQUE_ADDRESS_MAP" value="true" />
  <tag2 key="REPORT_HIERARCHY" value="false" />
  <tag2 key="SUPPORTED_FILE_SETS" value="QUARTUS_SYNTH" />
  <tag2 key="TCL_PACKAGE_VERSION" value="16.1" />
 </component>
