 <component name="altera_lvds_rx_28nm" file="../../../../mu3e_lvds_controller/altera_lvds_rx_28nm_hw.tcl" displayName="Altera LVDS RX (28nm)" version="24.0.1110" description="&lt;html&gt; Wrapper of the &lt;b&gt;&lt;i&gt;ALTLVDS_RX&lt;/i&gt;&lt;/b&gt; megafunction. &lt;br&gt; This IP is preset for Mu3e Experiment with following constrains:  &lt;ul&gt;  &lt;li&gt; operate only in &lt;b&gt;DPA-FIFO&lt;/b&gt; mode; &lt;i&gt; use SOFT-CDR mode requires a dedicated pin adjustment&lt;/i&gt; &lt;/li&gt;  &lt;li&gt; nicely grouped interfaces &lt;/li&gt;  &lt;li&gt; data rate and clock rate fixed &lt;/li&gt;  &lt;li&gt; use &lt;b&gt;internal PLL&lt;/b&gt; &lt;/li&gt; &lt;/ul&gt; Usage: &lt;ul&gt;  &lt;li&gt; connect &lt;b&gt;&lt;i&gt;serial&lt;/i&gt;&lt;/b&gt; interface =&gt; fast data input &lt;/li&gt;  &lt;li&gt; connect &lt;b&gt;&lt;i&gt;parallel&lt;/i&gt;&lt;/b&gt; interface =&gt; lvds controller, so it can decode 10b data into 8b &lt;/li&gt;  &lt;li&gt; connect &lt;b&gt;&lt;i&gt;ctrl&lt;/i&gt;&lt;/b&gt; interface =&gt; lvds controller &lt;/li&gt; &lt;/ul&gt;  &lt;br&gt; Remarks: &lt;br&gt; &lt;ul&gt;  &lt;li&gt; System-use: connects to &lt;b&gt;lvds_rx_controller_pro&lt;/b&gt; in normal operations. &lt;br&gt; &lt;/li&gt;  &lt;li&gt; Standalone-use: requires your own implementation of controller to perform decoding and bitslip. &lt;br&gt; &lt;/li&gt;  &lt;li&gt; &lt;b&gt;IMPORTANT&lt;/b&gt;: To prevent deadlock, the external lvds controller IP must NOT reply on &lt;i&gt;outclock&lt;/i&gt;, because it will not be running after you assert &lt;i&gt;pllrst&lt;/i&gt;.  &lt;/li&gt; &lt;/ul&gt;  &lt;br&gt; Data flow(clock domain): &lt;br&gt; DPA-circuitry(IOPLL) --1b--&gt; DPA FIFO(IOPLL) --1b--&gt; Bit Slip(IOPLL) --1b--&gt; Deserilizer(IOPLL|outclock) --10b--&gt; &lt;br&gt; &lt;br&gt; &lt;/html&gt;" tags="AUTHORSHIP=Yifeng Wang /// CONNECTION_TYPES=clock,conduit /// INTERNAL_COMPONENT=false" categories="Mu3e Data Plane/Modules" factory="TclModuleFactory">
  <tag2 key="ALLOW_GREYBOX_GENERATION" value="false" />
  <tag2 key="COMPONENT_EDITABLE" value="false" />
  <tag2 key="COMPONENT_HIDE_FROM_SOPC" value="true" />
  <tag2 key="ELABORATION_CALLBACK" value="my_elaborate" />
  <tag2 key="ICON_PATH" value="../../../misc/logo/mu3e_logo.png" />
  <tag2 key="INSTANTIATE_IN_SYSTEM_MODULE" value="true" />
  <tag2 key="OPAQUE_ADDRESS_MAP" value="true" />
  <tag2 key="REPORT_HIERARCHY" value="false" />
  <tag2 key="SUPPORTED_FILE_SETS" value="QUARTUS_SYNTH" />
  <tag2 key="TCL_PACKAGE_VERSION" value="16.1" />
 </component>
