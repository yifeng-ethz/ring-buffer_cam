 <component name="altera_lvds_mu3e" file="../../../../misc/altera_lvds/top/altera_lvds_hw.tcl" displayName="LVDS SERDES Intel FPGA IP" version="18.1" description="LVDS SERDES Intel FPGA IP" tags="AUTHORSHIP=Intel Corporation" categories="Basic Functions/I/O" factory="TclModuleFactory">
