	component feb_bringup_system is
		port (
			clk_in_clk          : in  std_logic                     := 'X';             -- clk
			reset_in_reset_n    : in  std_logic                     := 'X';             -- reset_n
			si_gpio_out_export  : out std_logic_vector(15 downto 0);                    -- export
			si_status_in_export : in  std_logic_vector(7 downto 0)  := (others => 'X')  -- export
		);
	end component feb_bringup_system;

