<?xml version="1.0" encoding="UTF-8"?>
<toolkit
        name="firefly_toolkit"
        displayName="FireFly ECUO 14G x4 (I2C) Monitor Toolkit (Beta)"
        addMenuItem="true"
        >
		<file>firefly_toolkit.tcl</file>
        
		<description>The toolkit allows the monitoring of FireFly Optical Tranceiver on FEB. It communicates in I2C protocol for VCC, temperature, RX optical power, etc.</description>
</toolkit>