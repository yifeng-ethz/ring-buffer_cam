set_global_assignment -name IP_TOOL_NAME "ALTIOBUF"
set_global_assignment -name IP_TOOL_VERSION "18.1"
set_global_assignment -name IP_GENERATED_DEVICE_FAMILY "{Arria V}"
set_global_assignment -name VHDL_FILE [file join $::quartus(qip_path) "alt_iobuf_onewire.vhd"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "alt_iobuf_onewire_inst.vhd"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "alt_iobuf_onewire.cmp"]
